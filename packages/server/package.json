{
  "name": "@vibewithme/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess 'node dist/index.js'",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@hocuspocus/server": "^3.4.4",
    "@hono/node-server": "^1.19.11",
    "@vibewithme/shared": "*",
    "argon2": "^0.44.0",
    "hono": "^4.12.8",
    "jose": "^6.2.2",
    "nanoid": "^5.1.7",
    "yjs": "^13.6.30"
  }
}
