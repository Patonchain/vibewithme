{
  "name": "@vibewithme/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess 'node dist/index.js'",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@vibewithme/shared": "*"
  }
}
